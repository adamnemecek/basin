{
  "name": "basin-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build ../crates/basin-wasm --target web --out-name basin_wasm --out-dir ../../web/src/lib/basin-wasm",
    "dev": "npm run build:wasm && vite dev",
    "build": "npm run build:wasm && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "svelte": "^5.55.7",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.6.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.10",
    "vite-plugin-wasm": "^3.4.0"
  }
}
