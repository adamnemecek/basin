{
  "name": "basin-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build ../crates/basin-wasm --target web --out-name basin_wasm --out-dir ../../web/src/lib/basin-wasm",
    "dev": "npm run build:wasm && vite dev",
    "build": "npm run build:wasm && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:snippets": "tsx scripts/check-snippets.ts",
    "collect:benchmarks": "tsx scripts/collect-benchmarks.ts"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.109",
    "@iconify-json/simple-icons": "^1.2.83",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.60.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/prismjs": "^1.26.6",
    "mdsvex": "^0.12.7",
    "prismjs": "^1.30.0",
    "svelte": "^5.55.7",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.6.0",
    "tsx": "^4.22.3",
    "typescript": "^5.4.0",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.10",
    "vite-plugin-wasm": "^3.4.0"
  }
}
